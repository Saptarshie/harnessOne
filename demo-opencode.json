{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git","context-mode"],
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "pdf": {
      "type": "local",
      "command": ["npx", "-y", "mcp-pdf"],
      "enabled": true
    },
    "openwork-ui": {
      "type": "local",
      "command": ["npx", "-y", "openwork-ui-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    },
  }
}